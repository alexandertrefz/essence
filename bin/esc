#!/usr/bin/env bun

import { readFile } from "node:fs/promises"
import path from "node:path"

import chalk from "chalk"

import { hideBin } from "yargs/helpers"
import yargs from "yargs/yargs"

import { containsErrors } from "../src/diagnostics/index"
import { renderDiagnostics } from "../src/diagnostics/render"
import { enrich } from "../src/enricher/index"
import { optimise } from "../src/optimiser/index"
import { parseWithDiagnostics } from "../src/parser/index"
import { rewrite } from "../src/rewriter/index"
import { simplify } from "../src/simplifier/index"
import { validate } from "../src/validator/index"

let argv = await yargs(hideBin(process.argv))
	.usage("Usage: $0 <fileName>")
	.option("outputFileName", {
		alias: "-o",
		type: "string",
		description:
			"The name of the output file. If not provided, defaults to the name of the input file.",
		requiresArg: true,
	})
	.option("execute", {
		alias: "-e",
		type: "boolean",
		description: "Executes the output with Bun, if set.",
	})
	.option("debug", {
		alias: "-d",
		type: "boolean",
		description: "Outputs various debugging information.",
	})
	.parse()

function printDiagnostics(diagnostics, sourceText, inputFileName) {
	if (diagnostics.length === 0) {
		return
	}

	let rendered = renderDiagnostics(diagnostics, sourceText, inputFileName, {
		color: chalk.level > 0,
	})

	console.error(rendered.replace(/\n$/, ""))
}

function generateOutputFilePath(inputFileName, outputFileName) {
	if (outputFileName === undefined) {
		outputFileName = `${path.basename(
			argv._[0].toString(),
			path.extname(argv._[0].toString()),
		)}.js`
	}

	return path.join(path.dirname(inputFileName), outputFileName)
}

async function compile(flags) {
	const start = performance.now()

	try {
		const data = await readFile(flags.inputFileName, "utf8")

		const { program: initialProgram, diagnostics: parserDiagnostics } =
			parseWithDiagnostics(data)

		printDiagnostics(parserDiagnostics, data, flags.inputFileName)

		if (containsErrors(parserDiagnostics)) {
			console.error(
				chalk.red(`Compilation of ${flags.inputFileName} failed.`),
			)
			process.exit(1)
		}

		const { program: enrichedProgram, diagnostics } =
			enrich(initialProgram)

		printDiagnostics(diagnostics, data, flags.inputFileName)

		if (containsErrors(diagnostics)) {
			console.error(
				chalk.red(`Compilation of ${flags.inputFileName} failed.`),
			)
			process.exit(1)
		}

		const validatorDiagnostics = validate(enrichedProgram)

		printDiagnostics(validatorDiagnostics, data, flags.inputFileName)

		if (containsErrors(validatorDiagnostics)) {
			console.error(
				chalk.red(`Compilation of ${flags.inputFileName} failed.`),
			)
			process.exit(1)
		}

		const simplifiedProgram = simplify(enrichedProgram)

		const optimisedProgram = optimise(simplifiedProgram)

		await rewrite(optimisedProgram, flags)

		const end = performance.now()

		console.log(
			`Successfully compiled ${chalk.cyan(
				flags.inputFileName,
			)} -> ${chalk.green(flags.outputFileName)} in ${chalk.magenta(
				Math.round(end - start) + "ms",
			)}`,
		)

		if (flags.execute) {
			const process = Bun.spawn(["bun", flags.outputFileName])
			console.log()
			console.log(chalk.magenta("Executing Program now."))
			console.log()
			console.log(await new Response(process.stdout).text())
		}
	} catch (error) {
		return Promise.reject(error)
	}

	return Promise.resolve(flags)
}

compile({
	inputFileName: argv._[0].toString(),
	execute: argv.execute ?? false,
	debug: argv.debug ?? false,
	outputFileName: generateOutputFilePath(
		argv._[0].toString(),
		argv.outputFileName,
	),
}).then(
	() => {},
	(error) => {
		console.error(error)
	},
)
