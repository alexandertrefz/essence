{
	"name": "essence-compiler",
	"version": "0.0.1",
	"description": "A new simple but powerful language.",
	"main": "index.js",
	"scripts": {
		"pre-commit": "bun compile-grammar && bun format && bun test",
		"compile-grammar": "nearleyc src/parser/grammar.ne -o src/parser/grammar.ts",
		"check": "biome check --write"
	},
	"keywords": [
		"language",
		"essence"
	],
	"author": "Alexander Trefz",
	"license": "MIT",
	"engines": {
		"bun": ">=1.0.x"
	},
	"devDependencies": {
		"@biomejs/biome": "2.3.2",
		"@types/bun": "1.3.1",
		"@types/deep-equal": "1.0.4",
		"@types/escodegen": "0.0.10",
		"@types/estree": "1.0.8",
		"@types/nearley": "2.11.5",
		"@types/yargs": "17.0.34",
		"husky": "9.1.7"
	},
	"dependencies": {
		"bigint-fraction": "1.0.6",
		"chalk": "5.6.2",
		"deep-equal": "2.2.3",
		"esbuild": "0.25.12",
		"escodegen": "alexandertrefz/escodegen",
		"nearley": "2.20.1",
		"typescript": "5.9.3",
		"yargs": "18.0.0"
	},
	"repository": {
		"url": "https://atrefz@github.com/atrefz/essence.git",
		"type": "git"
	},
	"trustedDependencies": [
		"@biomejs/biome",
		"esbuild"
	]
}
